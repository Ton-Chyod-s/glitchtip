# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/dbname

# Redis/Valkey (leave empty to disable)
VALKEY_URL=redis://...:6379/0

# Secret Key for Django (keep this secure)
SECRET_KEY=your-secret-key-here

# Server Configuration
PORT=8000
GLITCHTIP_DOMAIN=http://localhost:8000

# Email Configuration
# Note: For Gmail, use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_URL=smtp+ssl://your-email@gmail.com:YOUR_APP_PASSWORD@smtp.gmail.com:465
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Celery Worker Configuration
CELERY_WORKER_AUTOSCALE=1,2
